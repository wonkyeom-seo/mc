# 웹 관리 화면
HOST=127.0.0.1
PORT=3000
# LAN(0.0.0.0) 공개 시 반드시 설정하세요.
ADMIN_TOKEN=

# Minecraft 서버
MC_SERVER_DIR=./minecraft
MC_SERVER_JAR=server.jar
MC_JAVA_COMMAND=java
MC_MEMORY_MIN=1G
MC_MEMORY_MAX=2G
# JSON 배열 형식. 예: ["-XX:+UseG1GC"]
MC_EXTRA_JAVA_ARGS=[]
# JAR 뒤에 전달되는 서버 인자. Paper 웹 콘솔에서는 JLine을 사용하지 않습니다.
MC_SERVER_ARGS=["--nogui","--nojline"]
MC_STOP_TIMEOUT_MS=30000
# Java 프로세스 CPU/RSS 저장 주기 (최소 1000ms)
METRICS_INTERVAL_MS=5000
